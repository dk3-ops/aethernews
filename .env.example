# ============================================
# OMNISPHERE AI - ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and update with your values
# NEVER commit actual .env file to version control

# ============================================
# NODE ENVIRONMENT
# ============================================
NODE_ENV=development
# Options: development, staging, production
APP_ENV=development
PORT=3000
APP_NAME=omnisphere-ai
APP_VERSION=0.1.0
APP_URL=http://localhost:3000

# ============================================
# DATABASE - PostgreSQL
# ============================================
DATABASE_URL=postgresql://omnisphere_user:omnisphere_password@localhost:5432/omnisphere_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=omnisphere_db
DB_USER=omnisphere_user
DB_PASSWORD=omnisphere_password
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_SSL=false
# For production:
# DB_SSL=true
# DATABASE_URL=postgresql://user:password@prod-db.rds.amazonaws.com:5432/omnisphere_prod

# ============================================
# REDIS - Cache & Session
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# For cluster:
# REDIS_CLUSTER=true
# REDIS_SENTINEL_URLS=redis://sentinel1:26379,redis://sentinel2:26379

# ============================================
# SUPABASE - Backend as a Service
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-12345
JWT_EXPIRY=7d
JWT_REFRESH_SECRET=your-refresh-token-secret-key-12345
JWT_REFRESH_EXPIRY=30d
JWT_ALGORITHM=HS256

# ============================================
# BCRYPT PASSWORD HASHING
# ============================================
BCRYPT_ROUNDS=10
BCRYPT_SALT_LENGTH=10

# ============================================
# AI SERVICES
# ============================================
# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-pro
GEMINI_MAX_TOKENS=2048

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_ORG_ID=

# HuggingFace (optional)
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=gpt2

# Local AI Models
ENABLE_LOCAL_AI=true
LOCAL_AI_PORT=8003
LOCAL_MODEL_PATH=/models

# ============================================
# CLOUD STORAGE - AWS S3
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET=omnisphere-storage
S3_BUCKET_REGION=us-east-1
S3_FILE_EXPIRY=86400
S3_CLOUDFRONT_DOMAIN=https://your-cloudfront-domain.cloudfront.net
AWS_ENDPOINT=https://s3.amazonaws.com

# ============================================
# CDN - Cloudflare
# ============================================
CLOUDFLARE_ZONE_ID=your-zone-id
CLOUDFLARE_API_TOKEN=your-api-token
CLOUDFLARE_EMAIL=your-email@example.com
CLOUDFLARE_API_KEY=your-api-key
CDN_ENDPOINT=https://cdn.omnisphere.ai
CLOUDFLARE_CACHE_TTL=3600
ENABLE_CLOUDFLARE=true

# ============================================
# EMAIL SERVICE - SMTP
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=OmniSphere AI
SMTP_FROM_EMAIL=noreply@omnisphere.ai
SMTP_SECURE=true
ENABLE_EMAIL=true

# SendGrid (alternative)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ============================================
# PAYMENT PROCESSING
# ============================================
# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_API_VERSION=2023-10-16

# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET=your-paypal-secret
PAYPAL_MODE=sandbox
# For production:
# PAYPAL_MODE=live

# Razorpay (for India region)
RAZORPAY_KEY_ID=your-razorpay-key
RAZORPAY_KEY_SECRET=your-razorpay-secret

# ============================================
# AUTHENTICATION PROVIDERS - OAuth
# ============================================
# GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Facebook
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:3000/auth/facebook/callback

# Microsoft Azure
AZURE_AD_CLIENT_ID=your-azure-client-id
AZURE_AD_CLIENT_SECRET=your-azure-client-secret
AZURE_AD_TENANT_ID=your-tenant-id

# ============================================
# SECURITY & CORS
# ============================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002
CORS_CREDENTIALS=true
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS
ALLOWED_ORIGINS=localhost,127.0.0.1

# CSRF Protection
CSRF_ENABLED=true
CSRF_COOKIE_SECURE=false
# For production:
# CSRF_COOKIE_SECURE=true

# Helmet Security
HELMET_ENABLED=true
HELMET_CSP=true
HELMET_HSTS=true
HELMET_HSTS_MAX_AGE=31536000

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false
RATE_LIMIT_SKIP_FAILED_REQUESTS=false

# Per-endpoint limits
AUTH_RATE_LIMIT_WINDOW=15
AUTH_RATE_LIMIT_MAX=5

FILE_UPLOAD_RATE_LIMIT_WINDOW=60
FILE_UPLOAD_RATE_LIMIT_MAX=10

API_RATE_LIMIT_WINDOW=1
API_RATE_LIMIT_MAX=100

# ============================================
# FILE UPLOADS
# ============================================
MAX_FILE_SIZE=52428800
# 50MB in bytes
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx,ppt,pptx,mp4,avi,mov,mp3,wav
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,webp,svg
ALLOWED_VIDEO_TYPES=mp4,avi,mov,mkv,flv
ALLOWED_AUDIO_TYPES=mp3,wav,flac,aac,ogg

FILE_UPLOAD_PATH=/uploads
TEMP_UPLOAD_PATH=/tmp/uploads
ENABLE_VIRUS_SCAN=false

# ============================================
# WEBSOCKET CONFIGURATION
# ============================================
WEBSOCKET_ENABLED=true
WEBSOCKET_PORT=3002
WEBSOCKET_CORS=http://localhost:3000,http://localhost:3001
WEBSOCKET_PING_INTERVAL=30000
WEBSOCKET_PING_TIMEOUT=5000
WEBSOCKET_MAX_RECONNECT_ATTEMPTS=5
WEBSOCKET_RECONNECT_DELAY=1000

# ============================================
# LOGGING & MONITORING
# ============================================
LOG_LEVEL=info
# Options: error, warn, info, debug, trace
LOG_FORMAT=json
# Options: json, text, pretty
ENABLE_REQUEST_LOGGING=true
ENABLE_ERROR_LOGGING=true
LOGS_PATH=/var/logs/omnisphere

# Sentry Error Tracking
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACE_SAMPLE_RATE=0.1

# DataDog
DATADOG_ENABLED=false
DATADOG_API_KEY=
DATADOG_APP_KEY=

# ============================================
# SESSION MANAGEMENT
# ============================================
SESSION_SECRET=your-session-secret-key-change-in-production
SESSION_MAX_AGE=86400000
SESSION_SECURE=false
# For production:
# SESSION_SECURE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_STORE=redis

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_OFFLINE_MODE=true
FEATURE_AI_ASSISTANT=true
FEATURE_VIDEO_CALLS=true
FEATURE_LIVE_STREAMING=true
FEATURE_SOCIAL_MEDIA=true
FEATURE_CREATOR_TOOLS=true
FEATURE_PAYMENTS=true
FEATURE_MARKETPLACE=true
FEATURE_ADMIN_DASHBOARD=true
FEATURE_ANALYTICS=true

# ============================================
# MOBILE APP
# ============================================
MOBILE_APP_ENABLED=true
MOBILE_APP_SCHEME=omnisphere://
MOBILE_DEEP_LINK_ENABLED=true
MOBILE_UNIVERSAL_LINKS_DOMAIN=omnisphere.ai

# Firebase Cloud Messaging
FCM_PROJECT_ID=your-firebase-project-id
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=

# ============================================
# ANALYTICS & TRACKING
# ============================================
ANALYTICS_ENABLED=true
ANALYTICS_PROVIDER=mixpanel
# Options: mixpanel, segment, amplitude

MIXPANEL_TOKEN=
SEGMENT_WRITE_KEY=
AMPLITUDE_API_KEY=

ENABLE_USER_TRACKING=true
ENABLE_EVENT_TRACKING=true

# ============================================
# INTERNATIONALIZATION (i18n)
# ============================================
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,es,fr,de,zh,ja,hi,pt,ar
TIMEZONE=UTC
CURRENCY=USD

# ============================================
# KUBERNETES & DOCKER
# ============================================
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=
DOCKER_PASSWORD=
DOCKER_IMAGE_PREFIX=omnisphere

KUBERNETES_ENABLED=true
KUBERNETES_NAMESPACE=default
KUBERNETES_REPLICAS=3

# ============================================
# INTERNAL SERVICES
# ============================================
AI_SERVICE_URL=http://ai-service:8001
MEDIA_SERVICE_URL=http://media-service:8002
WEBSOCKET_SERVICE_URL=http://websocket-service:3002
ANALYTICS_SERVICE_URL=http://analytics-service:8003

# ============================================
# DEVELOPMENT ONLY
# ============================================
# These should NOT be used in production
DEBUG=false
MOCK_AI_RESPONSES=false
SKIP_EMAIL_VERIFICATION=false
SKIP_PAYMENT_VERIFICATION=false
ALLOW_INSECURE_REQUESTS=false
VERBOSE_LOGGING=false

# ============================================
# STAGING ENVIRONMENT
# ============================================
# Uncomment for staging deployment
# NODE_ENV=staging
# DATABASE_URL=postgresql://user:password@staging-db:5432/omnisphere_staging
# REDIS_URL=redis://redis-staging:6379
# JWT_SECRET=staging-secret-key-12345
# STRIPE_SECRET_KEY=sk_test_staging_key
# SENDGRID_API_KEY=staging-sendgrid-key

# ============================================
# PRODUCTION ENVIRONMENT
# ============================================
# Uncomment and configure for production
# NODE_ENV=production
# DATABASE_URL=postgresql://user:password@prod-db.rds.amazonaws.com:5432/omnisphere_prod
# REDIS_URL=redis://redis-cluster-prod:6379
# JWT_SECRET=production-secret-key-very-long-and-secure-12345
# STRIPE_SECRET_KEY=sk_live_production_key
# SENTRY_ENABLED=true
# LOG_LEVEL=warn
# HELMET_HSTS=true
# SESSION_SECURE=true
